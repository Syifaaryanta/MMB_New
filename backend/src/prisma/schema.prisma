// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 1. Profiles (User Management)
model Profile {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  nama       String
  role       Role     @default(staff_kantor)
  aktif      Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  purchases_created  Purchase[]         @relation("PurchaseCreatedBy")
  sales_created      Sale[]             @relation("SaleCreatedBy")
  payments_created   SalesPayment[]     @relation("PaymentCreatedBy")
  stock_adjustments  StockAdjustment[]  @relation("AdjustmentCreatedBy")
  billing_sessions   BillingSession[]   @relation("BillingSessionCreatedBy")
  supplier_payments  SupplierPayment[]  @relation("SupplierPaymentCreatedBy")

  @@map("profiles")
}

enum Role {
  admin
  staff_gudang
  staff_kantor
  sales
}

// 2. Products (Barang Gudang)
model Product {
  id          String   @id @default(uuid())
  kode        String   @unique
  nama        String
  deskripsi   String?  @db.Text
  stok        Decimal  @default(0.000) @db.Decimal(15, 3)
  satuan      String   @default("pcs")
  aktif       Boolean  @default(true)
  is_archived Boolean  @default(false)
  foto_urls   Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  product_prices        ProductPrice[]
  purchase_items        PurchaseItem[]
  sale_items            SaleItem[]
  stock_adjustments     StockAdjustment[]
  sale_return_items     SaleReturnItem[]
  purchase_return_items PurchaseReturnItem[]

  @@map("products")
}

// 3. Suppliers (Pemasok)
model Supplier {
  id                 String   @id @default(uuid())
  kode               String   @unique
  nama               String
  alamat             String?  @db.Text
  no_telp            String?
  jatuh_tempo_bulan  Int      @default(1)
  aktif              Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  // Relations
  product_prices ProductPrice[]
  purchases      Purchase[]

  @@map("suppliers")
}

// 4. Customers (Pelanggan)
model Customer {
  id                 String   @id @default(uuid())
  kode               String   @unique
  nama               String
  alamat             String?  @db.Text
  no_telp            String?
  jatuh_tempo_bulan  Int      @default(1)
  limit_kredit       Decimal  @default(10000000.00) @db.Decimal(15, 2)
  saldo_piutang      Decimal  @default(0.00) @db.Decimal(15, 2)
  aktif              Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  // Relations
  sales Sale[]

  @@map("customers")
}

// 5. Product Prices (Harga Barang per Supplier)
model ProductPrice {
  id          String   @id @default(uuid())
  product_id  String
  supplier_id String
  stok        Decimal  @default(0.000) @db.Decimal(15, 3)
  harga_beli  Decimal  @default(0.00) @db.Decimal(15, 2)
  aktif       Boolean  @default(true)
  updated_at  DateTime @updatedAt

  // Relations
  product  Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplier_id], references: [id], onDelete: Cascade)

  @@unique([product_id, supplier_id])
  @@map("product_prices")
}

// 6. Purchases (Order Beli / Purchase Order)
model Purchase {
  id          String         @id @default(uuid())
  no_order    String         @unique
  supplier_id String
  order_date  DateTime       @db.Date
  terms       String         @default("tunai") // 'tunai', '1', '2', '3'
  subtotal    Decimal        @default(0.00) @db.Decimal(15, 2)
  status      PurchaseStatus @default(draft)
  received_at DateTime?
  created_by  String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  biaya_pengiriman Decimal          @default(0.00) @db.Decimal(15, 2)

  // Relations
  supplier            Supplier            @relation(fields: [supplier_id], references: [id])
  creator             Profile?            @relation("PurchaseCreatedBy", fields: [created_by], references: [id])
  purchase_items      PurchaseItem[]
  purchase_returns    PurchaseReturn[]
  supplier_payments   SupplierPayment[]
  billing_allocations BillingAllocation[]

  @@map("purchases")
}

enum PurchaseStatus {
  draft
  completed
  received
}

// 7. Purchase Items (Detail Item PO)
model PurchaseItem {
  id          String  @id @default(uuid())
  purchase_id String
  product_id  String
  qty         Decimal @default(0.000) @db.Decimal(15, 3)
  harga_beli  Decimal @default(0.00) @db.Decimal(15, 2)
  subtotal    Decimal @default(0.00) @db.Decimal(15, 2)

  // Relations
  purchase Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [product_id], references: [id])

  @@map("purchase_items")
}

// 8. Sales (Order Jual / Sales Invoice)
model Sale {
  id                  String     @id @default(uuid())
  no_order            String     @unique
  no_faktur           String?    @unique
  order_date          DateTime   @db.Date
  customer_id         String
  customer_nama       String
  customer_alamat     String?    @db.Text
  customer_telp       String?
  diantar             Boolean    @default(true)
  limit_bulan         Int        @default(0)
  due_date            DateTime?  @db.Date
  extra_charge_desc   String?    @db.Text
  extra_charge_amount Decimal    @default(0.00) @db.Decimal(15, 2)
  sender_note         String?    @db.Text
  subtotal            Decimal    @default(0.00) @db.Decimal(15, 2)
  status              SaleStatus @default(draft)
  nota_merah          Boolean    @default(false)
  nota_putih          Boolean    @default(false)
  nota_kuning         Boolean    @default(true)
  print_count         Int        @default(0)
  created_by          String?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  biaya_pengiriman Decimal          @default(0.00) @db.Decimal(15, 2)

  // Relations
  customer            Customer            @relation(fields: [customer_id], references: [id])
  creator             Profile?            @relation("SaleCreatedBy", fields: [created_by], references: [id])
  sale_items          SaleItem[]
  sales_payments      SalesPayment[]
  sale_returns        SaleReturn[]
  billing_allocations BillingAllocation[]

  @@map("sales")
}

enum SaleStatus {
  draft
  completed
}

// 9. Sale Items (Detail Item Penjualan)
model SaleItem {
  id           String   @id @default(uuid())
  sale_id      String
  product_id   String
  product_kode String
  product_nama String
  qty          Decimal  @db.Decimal(15, 3)
  unit_price   Decimal  @db.Decimal(15, 2)
  total        Decimal  @db.Decimal(15, 2)
  created_at   DateTime @default(now())

  // Relations
  sale    Sale    @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])

  @@map("sale_items")
}

// 10. Sales Payments (Catatan Pembayaran Penagihan)
model SalesPayment {
  id             String   @id @default(uuid())
  sale_id        String
  payment_date   DateTime @db.Date
  amount         Decimal  @db.Decimal(15, 2)
  payment_method String   @default("cash")
  note           String?  @db.Text
  created_by     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  sale    Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  creator Profile? @relation("PaymentCreatedBy", fields: [created_by], references: [id])

  @@map("sales_payments")
}

// 11. Stock Adjustments (Histori Penyesuaian Stok Gudang)
model StockAdjustment {
  id              String   @id @default(uuid())
  product_id      String?
  product_kode    String   @default("")
  product_nama    String   @default("")
  adjustment_date DateTime @db.Date
  stock_before    Decimal  @default(0.000) @db.Decimal(15, 3)
  stock_after     Decimal  @default(0.000) @db.Decimal(15, 3)
  qty_delta       Decimal  @default(0.000) @db.Decimal(15, 3)
  staff_nama      String   @default("")
  alasan          String   @db.Text
  created_by      String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  product Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  creator Profile? @relation("AdjustmentCreatedBy", fields: [created_by], references: [id])

  @@map("stock_adjustments")
}

// 12. Retur Penjualan (Sales Returns)
model SaleReturn {
  id                String           @id @default(uuid())
  no_retur          String           @unique
  sale_id           String
  no_order          String
  no_faktur         String?
  customer_id       String
  customer_nama     String
  retur_date        DateTime         @db.Date
  total             Decimal          @default(0.00) @db.Decimal(15, 2)
  metode_kompensasi String           @default("potong_piutang")
  catatan           String?          @db.Text
  created_by        String?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  sale              Sale             @relation(fields: [sale_id], references: [id])
  items             SaleReturnItem[]

  @@map("sale_returns")
}

model SaleReturnItem {
  id           String     @id @default(uuid())
  retur_id     String
  product_id   String
  product_kode String
  product_nama String
  qty          Decimal    @db.Decimal(15, 3)
  unit_price   Decimal    @db.Decimal(15, 2)
  total        Decimal    @db.Decimal(15, 2)
  kondisi      String     @default("bagus") // bagus, rusak

  retur        SaleReturn @relation(fields: [retur_id], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [product_id], references: [id])

  @@map("sale_return_items")
}

// 13. Retur Pembelian (Purchase Returns)
model PurchaseReturn {
  id                String               @id @default(uuid())
  no_retur          String               @unique
  purchase_id       String
  no_order          String
  supplier_id       String
  supplier_nama     String
  retur_date        DateTime             @db.Date
  total             Decimal              @default(0.00) @db.Decimal(15, 2)
  metode_kompensasi String               @default("potong_hutang")
  catatan           String?              @db.Text
  created_by        String?
  created_at        DateTime             @default(now())
  updated_at        DateTime             @updatedAt

  purchase          Purchase             @relation(fields: [purchase_id], references: [id])
  items             PurchaseReturnItem[]

  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id           String         @id @default(uuid())
  retur_id     String
  product_id   String
  product_kode String
  product_nama String
  qty          Decimal        @db.Decimal(15, 3)
  unit_price   Decimal        @db.Decimal(15, 2)
  total        Decimal        @db.Decimal(15, 2)
  kondisi      String         @default("bagus") // bagus, rusak

  retur        PurchaseReturn @relation(fields: [retur_id], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [product_id], references: [id])

  @@map("purchase_return_items")
}

model BillingSession {
  id             String              @id @default(uuid())
  session_date   DateTime            @db.Date
  tipe           String              // "customer" atau "supplier"
  target_id      String              // ID Customer / ID Supplier
  target_nama    String              // Nama Customer / Nama Supplier
  total_amount   Decimal             @db.Decimal(15, 2)
  payment_method String              @default("cash") // "cash", "transfer", "cheque"
  mode           String              @default("fifo") // "fifo" atau "manual"
  catatan        String?             @db.Text
  created_by     String?
  created_at     DateTime            @default(now())

  // Relations
  creator        Profile?            @relation("BillingSessionCreatedBy", fields: [created_by], references: [id])
  allocations    BillingAllocation[]

  @@map("billing_sessions")
}

model BillingAllocation {
  id                 String          @id @default(uuid())
  billing_session_id String
  sale_id            String?
  purchase_id        String?
  allocated_amount   Decimal         @db.Decimal(15, 2)
  is_full_payment    Boolean         @default(false)
  remaining_after    Decimal         @db.Decimal(15, 2)
  created_at         DateTime        @default(now())

  // Relations
  session            BillingSession  @relation(fields: [billing_session_id], references: [id], onDelete: Cascade)
  sale               Sale?           @relation(fields: [sale_id], references: [id])
  purchase           Purchase?       @relation(fields: [purchase_id], references: [id])

  @@map("billing_allocations")
}

model SupplierPayment {
  id             String          @id @default(uuid())
  purchase_id    String
  payment_date   DateTime        @db.Date
  amount         Decimal         @db.Decimal(15, 2)
  payment_method String          @default("cash")
  note           String?         @db.Text
  created_by     String?
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  // Relations
  purchase       Purchase        @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  creator        Profile?        @relation("SupplierPaymentCreatedBy", fields: [created_by], references: [id])

  @@map("supplier_payments")
}

