{
  "name": "mmb-backend",
  "version": "1.0.0",
  "description": "Backend API for Maju Mulia Bersama system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
